import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import OneHotEncoder
from sklearn.linear_model import LogisticRegression, LinearRegression
from sklearn.compose import ColumnTransformer
from sklearn.pipeline import Pipeline
import matplotlib.pyplot as plt
import seaborn as sns

#Import Dataset
Ecommerce=pd.read_csv(r'C:\Users\ADMIN\Data_Science_and_AI\Spyder\Self_MachineLearning\Ecommerce_Data_Prediction\eCommerce_Data_Prediction.csv')

# Separate features & targets
x=Ecommerce[['time_on_site', 'pages_viewed', 'past_purchases', 'device', 'discount']]
y_class=Ecommerce['purchase']
y_reg=Ecommerce['amount']

# Handle categorical column
preprocessor = ColumnTransformer(
    transformers=[
        ('cat', OneHotEncoder(), ['device'])
    ],
    remainder='passthrough'
)

# Split train and test data
x_train,x_test,y_class_train, y_class_test=train_test_split(x,y_class,test_size=0.2,random_state=42)

## For regression (only where purchase = 1)
train_reg=Ecommerce[Ecommerce['purchase']==1]

x_reg=train_reg[['time_on_site', 'pages_viewed', 'past_purchases', 'device', 'discount']]
y_reg = train_reg['amount']

xr_train, xr_test, yr_train, yr_test = train_test_split(
    x_reg, y_reg, test_size=0.2, random_state=42)


# Build Classification Model
clf_pipeline = Pipeline(steps=[
    ('preprocessor', preprocessor),
    ('model', LogisticRegression())
])

clf_pipeline.fit(x_train, y_class_train)

# Build Regression Model
reg_pipeline = Pipeline(steps=[
    ('preprocessor', preprocessor),
    ('model', LinearRegression())
])

reg_pipeline.fit(xr_train, yr_train)

# Hybrid Prediction Logic
def hybrid_predict(input_df):
    # Step 1: classification
    purchase_pred = clf_pipeline.predict(input_df)[0]
    
    if purchase_pred == 1:
        # Step 2: regression
        amount_pred = reg_pipeline.predict(input_df)[0]
        return "Will Purchase", round(amount_pred, 2)
    else:
        return "Will NOT Purchase", 0

#Test it
sample = pd.DataFrame([{
    'time_on_site': 18,
    'pages_viewed': 12,
    'past_purchases': 6,
    'device': 'mobile',
    'discount': 25
}])

result = hybrid_predict(sample)

print(result)


